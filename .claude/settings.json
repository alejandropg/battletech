{
  "env": {
    "ENABLE_LSP_TOOL": "true"
  },
  "includeGitInstructions": false,
  "permissions": {
    "deny": [
      "Read(./.agent/**)",
      "Grep(./.agent/**)",
      "Bash(./.agent/**)",
      "Edit(./.agent/**)",
      "LSP(./.agent/**)",
      "Read(./.idea/**)",
      "Grep(./.idea/**)",
      "Bash(./.idea/**)",
      "Edit(./.idea/**)",
      "LSP(./.idea/**)",
      "Read(./.kotlin/**)",
      "Grep(./.kotlin/**)",
      "Bash(./.kotlin/**)",
      "Edit(./.kotlin/**)",
      "LSP(./.kotlin/**)"
    ]
  },
  "enabledPlugins": {
    "kotlin-lsp@claude-plugins-official": true
  }
}
